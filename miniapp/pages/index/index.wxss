.title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.theme-row {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.theme-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  margin-right: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.08);
  font-size: 24rpx;
  color: #374151;
}

.theme-item-active {
  background: linear-gradient(135deg, #6366f1, #ec4899);
  color: #ffffff;
}

.theme-icon {
  margin-right: 8rpx;
}

.question {
  margin-top: 8rpx;
  margin-bottom: 16rpx;
  width: 92%;
  margin-left: auto;
  margin-right: auto;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(15, 23, 42, 0.08);
  font-size: 26rpx;
  min-height: 160rpx;
}

.btn-primary {
  margin-top: 24rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, #6366f1, #ec4899);
  color: #ffffff;
  border-radius: 999rpx;
}

.confirm-btn {
  font-size: 28rpx;
  padding: 16rpx 60rpx;
}

.question-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.btn-secondary {
  flex: 0 0 auto;
  padding: 10rpx 32rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #6366f1, #ec4899);
  color: #ffffff;
  border-radius: 999rpx;
}

.btn-plain {
  flex: 0 0 auto;
  padding: 10rpx 32rpx;
  font-size: 26rpx;
  background: #ffffff;
  color: #374151;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.08);
}

.all-cards-circle {
  position: relative;
  width: 540rpx;
  height: 540rpx;
  margin: 132rpx auto 110rpx; /* 调整为略小的间距：原来 200rpx - 90rpx */
}

.all-card-selected {
  box-shadow: 0 0 0 4rpx #6366f1;
}

.all-card-circle {
  position: absolute;
  width: 150rpx;
  height: 210rpx;
  transform: translate(-50%, -50%);
}

.all-card-inner {
  width: 100%;
  height: 100%;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 10rpx 10rpx 12rpx 10rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.16);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
 
.all-card-image {
  width: 100%;
  height: 100%;
  border-radius: 14rpx;
}

.all-card-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #6366f1, #ec4899);
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.24);
}

.cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.12);
}

.card-image {
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  background: #e5e7eb;
}

.card-order {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
}

.card-meaning {
  font-size: 26rpx;
  color: #4b5563;
}

.ai-reading {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 30rpx rgba(15, 23, 42, 0.12);
}

.ai-reading-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #111827;
}

.ai-reading-text {
  font-size: 26rpx;
  color: #374151;
  white-space: pre-wrap;
}

.tip {
  margin-top: 32rpx;
  font-size: 20rpx;
  color: #9ca3af;
  text-align: center;
}


