<view class="page">
  <view class="title">AI 塔罗占卜（小程序版）</view>

  <!-- 主题选择（与网页版的 themes 同源） -->
  <scroll-view class="theme-row" scroll-x="true" enable-flex="true">
    <view
      wx:for="{{themes}}"
      wx:key="id"
      class="theme-item {{item.id === selectedThemeId ? 'theme-item-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onThemeTap"
    >
      <text class="theme-icon">{{item.icon}}</text>
      <text class="theme-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 问题/情绪输入（与网页版含义对应，暂不触发 AI，只参与记录） -->
  <textarea
    class="question"
    placeholder="请输入你想问的问题或当下的情绪（可选，多行文本）"
    value="{{emotionText}}"
    bindinput="onEmotionInput"
    auto-height
  ></textarea>

  <!-- 生成塔罗阵 / 重置 按钮 -->
  <view class="question-actions">
    <button class="btn-secondary" bindtap="onGenerateSpread">
      生成塔罗阵
    </button>
    <button class="btn-plain" bindtap="onReset">
      重置
    </button>
  </view>

  <!-- 所有牌由用户自行选择三张 -->
  <view class="all-cards-circle">
    <view
      wx:for="{{circleCards}}"
      wx:key="id"
      class="all-card-circle {{selectedCardIds.indexOf(item.id) !== -1 ? 'all-card-selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="onCardTap"
      style="left: {{item.left}}rpx; top: {{item.top}}rpx;"
    >
      <!-- 所有卡片的正面样式统一展示为牌背，与网页版一致 -->
      <view class="all-card-inner">
        <image class="all-card-image" src="/tarot-back.png" mode="aspectFill" />
      </view>

      <!-- 选中序号标记 -->
      <view
        wx:if="{{item.selectionIndex > 0}}"
        class="all-card-badge"
      >
        {{item.selectionIndex}}
      </view>
    </view>
  </view>

  <button
    class="btn-primary confirm-btn"
    bindtap="onConfirmSelection"
    disabled="{{selectedCardIds.length !== 3}}"
  >
    已选 {{selectedCardIds.length}} / 3 张，确认并生成解读
  </button>

  <!-- 抽到的三张牌 -->
  <view class="cards" wx:if="{{drawnCards.length}}">
    <view wx:for="{{drawnCards}}" wx:key="id" class="card">
      <image class="card-image" src="{{item.image}}" mode="aspectFit" />
      <view class="card-order">第{{item.order}}张牌 {{item.reversed ? '（逆位）' : '（正位）'}}</view>
      <view class="card-name">{{item.name}} {{item.nameEn}}</view>
      <view class="card-meaning">{{item.meaning}}</view>
    </view>
  </view>

  <!-- AI 解读占位文案 -->
  <view wx:if="{{aiReading}}" class="ai-reading">
    <view class="ai-reading-title">AI 解读（占位示意）</view>
    <view class="ai-reading-text">{{aiReading}}</view>
  </view>

  <view class="tip">
    当前为简化版流程：使用与网页版一致的牌面图片，用户手动选择三张牌后生成占位解读文本。之后可以按你的接口接入真实 AI 解读。
  </view>
</view>


