<view class="page gradient-bg">
  <view class="header card" style="margin: 40rpx 32rpx 24rpx;">
    <view style="display: flex; justify-content: space-between; align-items: center;">
      <view>
        <view class="text-title">AI 塔罗占卜</view>
        <view class="text-subtitle" style="margin-top: 8rpx;">
          抽三张牌，听听宇宙今天给你的回应
        </view>
      </view>
      <view style="text-align: right;">
        <view class="tag" style="background: rgba(124, 58, 237, 0.1); color: #7c3aed;">
          🔮 灵感指引
        </view>
      </view>
    </view>
  </view>

  <view class="card" style="margin: 0 32rpx 24rpx;">
    <view style="font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: #1f2937;">
      选择你想占卜的主题
    </view>

    <view style="display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; align-items: center; width: 100%; box-sizing: border-box;">
      <block wx:for="{{themes}}" wx:key="id">
        <view
          class="theme-pill"
          bindtap="onSelectTheme"
          data-id="{{item.id}}"
          style="{{item.styleStr}} flex: 0 0 30%; max-width: 200rpx;"
        >
          <text style="font-size: 32rpx;">{{item.icon}}</text>
          <text style="font-size: 22rpx; font-weight: 600; color: #1f2937; text-align: center;">
            {{item.name}}
          </text>
        </view>
      </block>
    </view>
  </view>

  <view class="card" style="margin: 0 32rpx 24rpx;">
    <view style="font-size: 28rpx; font-weight: 600; margin-bottom: 12rpx; color: #1f2937;">
      想对塔罗说的话（可选）
    </view>
    <view class="text-muted" style="font-size: 24rpx; margin-bottom: 16rpx;">
      写下此刻的情绪、问题或你在意的情境，会让解读更贴近你。
    </view>

    <textarea
      class="emotion-input"
      placeholder="例如：最近感情有点迷茫，总是重复类似的模式，不知道该怎么走出去。"
      placeholder-class="emotion-placeholder"
      value="{{emotionText}}"
      bindinput="onEmotionInput"
      maxlength="180"
      auto-height="true"
      style="width: 100%; min-height: 180rpx; border-radius: 20rpx; padding: 20rpx; font-size: 26rpx; background: rgba(255,255,255,0.5); border: 1rpx solid rgba(148,163,184,0.3); color: #374151; box-sizing: border-box; line-height: 1.6;"
    />

    <view style="display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx;">
      <view class="text-muted" style="font-size: 22rpx;">
        当前字数：{{emotionText.length}} / 180
      </view>
      <view class="text-muted" style="font-size: 22rpx;">
        今天的你，被允许好好表达自己 🌙
      </view>
    </view>
  </view>

  <view class="card" style="margin: 0 32rpx 24rpx;">
    <view style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx;">
      <view style="font-size: 28rpx; font-weight: 600; color: #1f2937;">
        抽三张牌 · 今日的指引
      </view>
      <view class="tag" style="background: rgba(56, 189, 248, 0.15); color: #0284c7;">
        三张牌阵：现状 · 阻碍 · 走向
      </view>
    </view>

    <view style="margin-bottom: 20rpx;" wx:if="{{selectedCards.length}}">
      <view style="display: flex; justify-content: space-between; gap: 16rpx;">
        <block wx:for="{{selectedCards}}" wx:key="id" wx:for-index="idx">
          <view style="flex: 1; align-items: center; text-align: center;">
            <view 
              style="height: 200rpx; border-radius: 12rpx; background: {{flippedCards.includes(idx) ? '#ffffff' : '#7c3aed'}}; border: 1rpx solid rgba(148,163,184,0.3); display: flex; align-items: center; justify-content: center; margin-bottom: 10rpx; box-shadow: 0 4rpx 12rpx rgba(31, 38, 135, 0.08); overflow: hidden;"
              bindtap="onCardFlip"
              data-index="{{idx}}"
            >
              <image 
                wx:if="{{flippedCards.includes(idx)}}"
                src="{{item.image}}" 
                mode="aspectFit"
                style="width: 100%; height: 100%; transform: {{item.reversed ? 'rotate(180deg)' : 'rotate(0deg)'}};"
              />
              <view wx:else style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #7c3aed;">
                <image 
                  src="/tarot-back.png" 
                  mode="aspectFit"
                  style="width: 100%; height: 100%;"
                  lazy-load="true"
                />
              </view>
            </view>
            <text style="font-size: 24rpx; color: #374151;">
              {{flippedCards.includes(idx) ? (item.name + (item.reversed ? '（逆位）' : '（正位）')) : '点击翻牌'}}
            </text>
          </view>
        </block>
      </view>
    </view>

    <view wx:if="{{!showAllCards}}">
      <button
        class="btn-primary"
        style="margin-top: 8rpx; padding: 20rpx 0; font-size: 28rpx;"
        bindtap="onShowCardSelection"
      >
        {{selectedCards.length ? '重新选择牌' : '选择三张牌'}}
      </button>
      
      <button
        wx:if="{{selectedCards.length === 3}}"
        class="btn-primary"
        style="margin-top: 16rpx; padding: 20rpx 0; font-size: 28rpx;"
        loading="{{loading}}"
        disabled="{{loading}}"
        bindtap="onDrawAndAsk"
      >
        {{loading ? '正在为你解读牌面…' : '开始解读'}}
      </button>
    </view>

    <view wx:if="{{showAllCards}}" style="margin-top: 20rpx;">
      <view style="font-size: 26rpx; font-weight: 600; margin-bottom: 16rpx; color: #1f2937; text-align: center;">
        请选择3张牌（已选择 {{selectedCardIds.length}}/3）
      </view>
      <view style="display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; max-height: 800rpx; overflow-y: auto;">
        <block wx:for="{{allTarotCards}}" wx:key="id">
          <view
            style="width: 140rpx; height: 200rpx; border-radius: 12rpx; border: 2rpx solid {{selectedCardIds.includes(item.id) ? 'rgba(124, 58, 237, 0.8)' : 'rgba(148,163,184,0.3)'}}; background: #7c3aed; box-shadow: {{selectedCardIds.includes(item.id) ? '0 4rpx 12rpx rgba(124, 58, 237, 0.3)' : '0 2rpx 8rpx rgba(0, 0, 0, 0.05)'}}; overflow: hidden; position: relative;"
            bindtap="onCardSelect"
            data-id="{{item.id}}"
          >
            <image 
              src="/tarot-back.png" 
              mode="aspectFit"
              style="width: 100%; height: 100%;"
              lazy-load="true"
            />
          </view>
        </block>
      </view>
      <button
        class="btn-primary"
        style="margin-top: 24rpx; padding: 20rpx 0; font-size: 28rpx;"
        bindtap="onConfirmCardSelection"
      >
        确认选择
      </button>
    </view>

    <view wx:if="{{readingText}}" style="margin-top: 24rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(148,163,184,0.3);">
      <view style="font-size: 26rpx; font-weight: 600; margin-bottom: 12rpx; display: flex; align-items: center; gap: 8rpx; color: #1f2937;">
        <text>✨ 解读结果</text>
      </view>
      <view style="font-size: 26rpx; line-height: 1.7; white-space: pre-wrap; color: #374151;">
        {{readingText}}
      </view>
    </view>

    <view wx:if="{{!readingText && !loading}}" style="margin-top: 18rpx; font-size: 24rpx;" class="text-muted">
      抽牌后，AI 会结合你选择的主题和当下的情绪，为你生成一份五段式塔罗解析。
    </view>
  </view>

  <view style="height: 40rpx;"></view>
</view>


